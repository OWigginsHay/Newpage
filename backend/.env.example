# Copy to `.env` and fill in. Only OPENAI_API_KEY is required to chat.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_REASONING=none   # none|low|medium|high|xhigh|max (reasoning-capable models only)

# Embeddings + vector store
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PATH=./.chroma
CHROMA_COLLECTION=documents

# Chunking (character windows)
CHUNK_WINDOW=1000
CHUNK_OVERLAP=150

# Retrieval + agent loop
TOP_K=5
MAX_TOOL_ITERATIONS=6
